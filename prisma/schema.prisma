generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Borramos las líneas de url y directUrl de aquí
}

enum Category {
  Carcasa
  Lamina
  Cargador
  Cable
  Audifonos
  Vapers
  Computacion
  Otros
}

enum DeliveryType {
  retiro
  despacho
}

model Product {
  id          String           @id @default(cuid())
  name        String
  description String?
  price       Float
  stock       Int              @default(0)
  imageUrl    String?
  category    Category?
  createdAt   DateTime         @default(now())
  orderItems  OrderItem[]
  discounts   DiscountRule[]
  images      ProductImage[]
  variants    ProductVariant[]
}

model ProductVariant {
  id String @id @default(cuid())

  size String

  stock Int @default(0)

  imageUrl String?

  productId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  images ProductVariantImage[]
}

model ProductVariantImage {
  id String @id @default(cuid())

  url String

  order Int @default(0)

  variantId String

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  order     Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id               String       @id @default(cuid())
  total            Float
  status           String       @default("pending")
  paymentMethod    String       @default("transfer")
  paymentStatus    String       @default("pending_payment")
  paymentProvider  String       @default("manual")
  paymentReference String?
  paymentUrl       String?
  webpayToken       String?
  webpayBuyOrder    String?
  webpaySessionId   String?
  webpayResponseCode Int?
  webpayAuthorizationCode String?
  webpayCardLastDigits String?
  webpayInstallmentsNumber Int?
  paidAt           DateTime?
  // Datos del cliente
  customerName     String?
  customerPhone    String?
  customerEmail    String?
  // Entrega
  deliveryType     DeliveryType @default(retiro)
  deliverySucursal String? // "Chacabuco 479" o "Chacabuco 456" — solo si retiro
  deliveryAddress  String? // Dirección completa — solo si despacho
  deliveryCity     String? // Ciudad — solo si despacho
  deliveryNotes    String? // Instrucciones adicionales
  createdAt        DateTime     @default(now())
  items            OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Float
  size      String?
  productId String
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  order     Order   @relation(fields: [orderId], references: [id])
}

model DiscountRule {
  id          String   @id @default(cuid())
  name        String
  type        String
  value       Float
  minQuantity Int      @default(1)
  active      Boolean  @default(true)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  createdAt   DateTime @default(now())
}
