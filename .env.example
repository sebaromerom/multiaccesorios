# Base de datos y autenticacion
DATABASE_URL=
NEXTAUTH_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Aplicacion publica
NEXT_PUBLIC_APP_URL=https://multiaccesorios.cl
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Webpay: no se habilita en produccion hasta completar estas variables.
WEBPAY_ENV=production
WEBPAY_COMMERCE_CODE=
WEBPAY_API_KEY=

# Mercado Pago Checkout Pro
CHECKOUT_ENABLE_MERCADOPAGO=false
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# Checkout seguro por defecto
CHECKOUT_ENABLE_PAY_ON_PICKUP=true
CHECKOUT_ENABLE_TRANSFER=false
CHECKOUT_ENABLE_PAYMENT_LINK=false

# El despacho web permanece bloqueado hasta implementar costo y cobertura.

# Requeridas antes de habilitar transferencia
BANK_ACCOUNT_HOLDER=
BANK_NAME=
BANK_ACCOUNT_TYPE=
BANK_ACCOUNT_NUMBER=
BANK_ACCOUNT_RUT=

# Bsale se mantiene solo como lectura y no participa del checkout.
BSALE_ACCESS_TOKEN=
BSALE_PRICE_LIST_ID=1
BSALE_OFFICE_ID=1
